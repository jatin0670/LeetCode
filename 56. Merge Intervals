SOLUTIO 1:
TC : O(n^3)
SC : O(n)

class Solution {

    public boolean isOverlap(int[] int1, int[] int2){
        if(int1[1]>=int2[0] && int2[1]>=int1[0]){
            return true;
        }
        return false;
    }

    public int[][] merge(int[][] intervals) {
        
    List<int[]> list = new ArrayList<>();

    for(int[] interval : intervals){
        list.add(interval);
    }

    boolean mergedHappend = true;

    while(mergedHappend){
        
        mergedHappend = false;

        for(int i = 0; i<list.size(); i++){
            int j = i+1;
            while(j<list.size()){
                int[] int1 = list.get(i);
                int[] int2 = list.get(j);


                if(isOverlap(int1, int2)){
                    int1[0] = Math.min(int1[0], int2[0]);
                    int1[1] = Math.max(int1[1], int2[1]);
                    mergedHappend = true;
                    list.remove(j);
                }
                else{
                    j++;
                }
            }
        }

    }

    int[][] ans = new int[list.size()][2];

    for(int i =0; i<list.size(); i++){
        ans[i] = list.get(i);
    }


    return ans;

    }
}
