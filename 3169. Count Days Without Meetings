SOLUTION 1:
TC : O(n logn)
SC : O(n)

class Solution {
    public int countDays(int days, int[][] meetings) {
        List<int[]> res = new ArrayList<>();

        Arrays.sort(meetings, Comparator.comparingInt(a->a[0]));

        res.add(meetings[0]);

        for(int i =1; i<meetings.length; i++){
            if(res.get(res.size()-1)[1] >= meetings[i][0]){
                res.get(res.size()-1)[0] = Math.min(
                    res.get(res.size()-1)[0], meetings[i][0]
                );

                res.get(res.size()-1)[1] = Math.max(
                    res.get(res.size()-1)[1], meetings[i][1]
                );
            }
            else{
                res.add(meetings[i]);
            }
        }

        int gap = 0;

        for(int j = 1; j<res.size(); j++){
            gap = gap + (res.get(j)[0] - res.get(j-1)[1]) - 1;
        }

        gap+= res.get(0)[0] - 1;
        gap+= days - res.get(res.size()-1)[1];

        return gap;
    }
}


SOLUTION 2: here we counts the meetings days then subtract from available days
TC : O(n logn)
SC : O(n)

class Solution {
    public int countDays(int days, int[][] meetings) {
        List<int[]> res = new ArrayList<>();

        Arrays.sort(meetings, Comparator.comparingInt(a->a[0]));

        res.add(meetings[0]);

        for(int i =1; i<meetings.length; i++){
            if(res.get(res.size()-1)[1] >= meetings[i][0]){
                res.get(res.size()-1)[0] = Math.min(
                    res.get(res.size()-1)[0], meetings[i][0]
                );

                res.get(res.size()-1)[1] = Math.max(
                    res.get(res.size()-1)[1], meetings[i][1]
                );
            }
            else{
                res.add(meetings[i]);
            }
        }

        int meetingDays = 0;

        for(int j = 0; j<res.size(); j++){
            meetingDays = meetingDays + (res.get(j)[1] - res.get(j)[0]) + 1;
        }


        return days - meetingDays;
    }
}


SOLUTION 3:
TC : O(n logn)
SC : O(sorting program space complexity)

class Solution {
    public int countDays(int days, int[][] meetings) {
        

        Arrays.sort(meetings, Comparator.comparingInt(a->a[0]));

        int maxEnd = meetings[0][1];
        int gap = 0;

        for(int i = 1; i<meetings.length; i++){
            if(meetings[i][0] > maxEnd){
                gap = gap + meetings[i][0] - maxEnd - 1;
            }

            maxEnd = Math.max(maxEnd, meetings[i][1]);
        }

        gap = gap + meetings[0][0] - 1;
        gap = gap + days - maxEnd;

        return gap;
    }
}
