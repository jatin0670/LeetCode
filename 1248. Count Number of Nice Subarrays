SOLUTION 1:
TC : O(2 * 2n)
SC : O(1)


class Solution {
    public int numberOfSubarrays(int[] nums, int k) {
        return solution(nums, k) - solution(nums, k-1);
    }

    public int solution(int[] nums, int k){
        
        int l = 0; int r = 0; int count = 0; int sum=0;

        if(k<0){
            return 0;
        }

        while(r < nums.length){ 
            sum += nums[r] % 2;

           
            while(sum > k){
                sum-=nums[l] % 2;
                l++;
            }

            count+= r-l+1;
            r++;


        }


        return count;
    }
}
