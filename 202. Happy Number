SOLUTION 1:
TC : O(log n)
SC : O(1)

class Solution {
    public boolean isHappy(int n) {
        int slow = n;
        int fast = n;

        while(fast != 1){
            slow = sqrt(slow);
            fast = sqrt(sqrt(fast));

            if(fast == 1){
                return true;
            }

            if(slow == fast){
                return false;
            }

        }

        return true;
    }

    public int sqrt(int n){
        int sum = 0;

        while(n > 0){
            int rem = n % 10;
            sum+= rem * rem;
            n/= 10;
        }

        return sum;
    }
}



SOLUTION 2:
TC : O(log n)
SC:  O(1)

class Solution {
    public boolean isHappy(int n) {
        int slow = n;
        int fast = n;

        do{
            slow = sqrt(slow);
            fast = sqrt(sqrt(fast));
        }while(slow!=fast);

        if(slow == 1){
            return true;
        }
        return false;
    }

    private int sqrt(int number){
        int sum = 0;
        while(number>0){
            int rem = number % 10;
            sum += rem*rem;
            number /=10;
        }
        return sum;
    }
}
