SOLUTION 1:
TC : O(2n)
SC : O(n) 

class Solution {
    public int subarraysWithKDistinct(int[] nums, int k) {
        return solution(nums, k) - solution(nums, k-1);
    }

    public int solution(int[] nums, int k){
        int l = 0; int r = 0; int count = 0; 
        HashMap<Integer, Integer> map = new HashMap<>();

        while(r < nums.length){
              map.compute(nums[r], (key, v) ->(v == null ? 1 : v+1));

              while(map.size() > k){
                map.compute(nums[l], (key, v)->(v >= 1 ? v-1 : 0));

                if(map.get(nums[l]) == 0){
                    map.remove(nums[l]);
                }
                 l++;
              }

               count+= r-l+1;

              r++;
        }

        return count;
    }
}
