SOLUTION 1:
TC : O(n)
SC :  O(1)

class Solution {
    public ListNode reverseList(ListNode head) {
        ListNode prev = null;
        ListNode curr = head;

        while(curr != null){
            ListNode next = curr.next;

           curr.next = prev;

            prev = curr;

            curr = next;

            if(next != null){
                next = next.next;
            }
        }

        return prev;
    }
}
