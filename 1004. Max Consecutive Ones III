SOLUTION 1: 
TC: O(n²), SC: O(1)

class Solution {
    public int longestOnes(int[] nums, int k) {
         int maxlen = 0;
        for(int i =0; i<nums.length; i++){
            int maxZero = 0;
            for(int j =i; j<nums.length; j++){
                if(nums[j] == 0){
                    maxZero++;
                }

                if(maxZero <= k){
                    int len = j - i + 1;
                    maxlen = Math.max(maxlen, len);
                }
                else{
                    break;
                }
            }
        }

        return maxlen;
    }
}


SOLUTION 2: 
TC: O(2n), SC: O(1)

class Solution {
    public int longestOnes(int[] nums, int k) {
        int l = 0;
        int r = 0;
        int maxlen = 0;
        int zero = 0;

        while(r < nums.length){
            if(nums[r] == 0){
               zero++;
            }

            while(zero > k){
                if(nums[l] == 0){
                    zero--;
                }
                l++;
            }

            if(zero <= k){
                int len = r - l + 1;
                maxlen = Math.max(maxlen, len);
            }

            r++;
        }

        return maxlen;
}
}
