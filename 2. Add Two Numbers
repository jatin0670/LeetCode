class Solution {
    public ListNode addTwoNumbers(ListNode l1, ListNode l2) {
        ListNode t1 = l1;
        ListNode t2 = l2;
        ListNode dum = new ListNode(-1);
        ListNode temp = dum;

        int sum = 0;
        int carry = 0;

        while(t1 != null || t2 != null){

            sum = sum + carry;

            if(t1!= null){
                sum+= t1.val;
                t1 = t1.next;
            }else{
                sum+= 0;
            }

            if(t2!= null){
                sum+= t2.val;
                t2 = t2.next;
            }
            else{
                sum+=0;
            }

            carry = sum/10;
            sum = sum%10;

            temp.next = new ListNode(sum);
            temp = temp.next;
            sum = 0;

            
        }

        if(carry == 1 ){
                temp.next = new ListNode(1);
            }

        return dum.next;

    }
}


